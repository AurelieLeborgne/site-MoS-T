---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MemberCard from '../../components/MemberCard.astro';
import { t } from '../../i18n/utils';

const lang = 'fr';
const base = '/site-MoS-T';

const permanentMembers = [
  {
    name: 'Aurélie Leborgne',
    role: 'Responsable scientifique',
    affiliation: 'ICube, Université de Strasbourg',
    photo: `${base}/images/members/Aurelie.jpg`,
    url: 'https://aurelieleborgne.github.io/webpage/',
    description: 'Aurélie travaille sur la modélisation et l\'analyse de données spatio-temporelles. Elle modélise des données provenant du domaine médical (IRMf) et du domaine environnemental (RPG, Corine Land Cover) à l\'aide de graphes spatio-temporels, et a travaillé sur l\'extraction de motifs fréquents dans ces graphes.',
  },
  {
    name: 'Antoine Vacavant',
    role: 'Co-responsable',
    affiliation: 'Institut Pascal, Université Clermont Auvergne',
    photo: `${base}/images/members/Antoine.jpg`,
    url: 'http://antoine-vacavant.eu/',
    description: 'Antoine est spécialisé en apprentissage profond sur graphes pour l\'analyse et le traitement d\'images. Ses recherches portent principalement sur le diagnostic assisté par ordinateur à partir d\'images (bio)médicales. Il est également instructeur au NVIDIA Deep Learning Institute.',
  },
  {
    name: 'Antonio Capobianco',
    role: 'Chercheur',
    affiliation: 'ICube, Université de Strasbourg',
    photo: `${base}/images/members/Antonio.jpg`,
    url: 'https://www.linkedin.com/in/antonio-capobianco-unistra',
    description: 'Antonio est spécialiste en Interaction Homme-Machine, Réalité Virtuelle et Interaction 3D. Il s\'intéresse aux problématiques utilisateurs, notamment pour la visualisation et le traitement de l\'information.',
  },
  {
    name: 'Céline Meillier',
    role: 'Chercheuse',
    affiliation: 'ICube, Université de Strasbourg',
    photo: '',
    url: 'https://images.icube.unistra.fr/index.php/C%C3%A9line_Meillier',
    description: 'Céline travaille sur la modélisation spatio-temporelle de la dynamique de la connectivité fonctionnelle par l\'analyse de signaux issus de données IRMf. Elle travaille également sur les techniques de seuillage multiple pour les corrélations significatives de signaux IRMf.',
  },
  {
    name: 'Thomas Lampert',
    role: 'Chercheur',
    affiliation: 'ICube, Université de Strasbourg',
    photo: `${base}/images/members/Tom.jpg`,
    url: 'https://sites.google.com/site/tomalampert',
    description: 'Thomas est expert en apprentissage automatique, en particulier l\'apprentissage profond et les approches semi-supervisées et non supervisées. Ses recherches portent sur l\'adaptation de domaine et l\'apprentissage de représentations pour l\'analyse d\'images et de séries temporelles.',
  },
  {
    name: 'Florence Le Ber',
    role: 'Chercheuse',
    affiliation: 'ICube, ENGEES',
    photo: `${base}/images/members/flbweb.png`,
    url: 'https://sdc.icube.unistra.fr/en/index.php/Florence_le_Ber',
    description: 'Florence travaille sur la modélisation et la représentation des connaissances, le raisonnement spatial, et l\'extraction de connaissances à partir de données temporelles et spatiales. Ses applications couvrent l\'agriculture, l\'hydroécologie et les problématiques environnementales.',
  },
];

const nonPermanentMembers = [
  {
    name: 'Assaad Zeghina',
    role: 'Doctorant',
    affiliation: 'ICube, Université de Strasbourg',
    photo: `${base}/images/members/Assaad.jpg`,
    url: 'https://drassaadz.github.io/',
    description: 'Assaad a obtenu son Master en Machine Learning à l\'Université de Paris. Ses recherches portent sur les réseaux de neurones sur graphes, l\'apprentissage profond et la vision par ordinateur.',
  },
  {
    name: 'Julien Pontabry',
    role: 'Ingénieur de recherche',
    affiliation: 'ICube, Université de Strasbourg',
    photo: `${base}/images/members/Julien.jpg`,
    url: 'https://www.linkedin.com/in/julien-pontabry-b784a247/',
    description: 'Julien est ingénieur de recherche au laboratoire ICube, rattaché à la plateforme technologique GAIA et à l\'équipe de recherche IMIS. Il travaille sur l\'IA appliquée à l\'imagerie biomédicale.',
  },
];
---

<BaseLayout lang={lang} currentPath="/equipe/" title={`${t(lang, 'team.title')} — MoS-T`}>
  <div class="pt-24 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-dark dark:text-white mb-4">
        {t(lang, 'team.title')}
      </h1>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-500 to-lime-500 rounded-full"></div>
    </section>

    <!-- Permanent members -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <h2 class="text-2xl md:text-3xl font-bold text-dark dark:text-white mb-8">
        {t(lang, 'team.permanent')}
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {permanentMembers.map((member) => (
          <MemberCard {...member} />
        ))}
      </div>
    </section>

    <!-- Non-permanent members -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-dark dark:text-white mb-8">
        {t(lang, 'team.non_permanent')}
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {nonPermanentMembers.map((member) => (
          <MemberCard {...member} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
