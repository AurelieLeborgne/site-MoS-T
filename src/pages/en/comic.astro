---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
const base = import.meta.env.BASE_URL;

const totalPages = 10;
const pages = Array.from({ length: totalPages }, (_, i) => ({
  src: `${base}/images/comic/${i + 1}.png`,
  alt: `${t(lang, 'comic.page_label')} ${i + 1}`,
}));
---

<BaseLayout lang={lang} currentPath="/comic/" title={`${t(lang, 'comic.title')} — MoS-T`} description={t(lang, 'comic.description') as string}>
  <div class="pt-24 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-dark dark:text-white mb-4">
        {t(lang, 'comic.title')}
      </h1>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-500 to-lime-500 rounded-full mb-4"></div>
      <p class="text-lg text-gray-600 dark:text-gray-300">{t(lang, 'comic.description')}</p>
    </section>

    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="comic-reader" class="relative">
        <div class="relative bg-white dark:bg-dark rounded-2xl border border-gray-100 dark:border-gray-800 shadow-lg overflow-hidden">
          <button
            id="comic-prev"
            type="button"
            class="absolute left-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 md:w-12 md:h-12 rounded-full bg-dark/60 hover:bg-dark/80 text-white flex items-center justify-center transition-all disabled:opacity-30 disabled:cursor-not-allowed"
            aria-label={t(lang, 'comic.prev') as string}
          >
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>

          <button
            id="comic-next"
            type="button"
            class="absolute right-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 md:w-12 md:h-12 rounded-full bg-dark/60 hover:bg-dark/80 text-white flex items-center justify-center transition-all disabled:opacity-30 disabled:cursor-not-allowed"
            aria-label={t(lang, 'comic.next') as string}
          >
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>

          <div id="comic-canvas" class="flex items-center justify-center min-h-[300px] md:min-h-[500px]">
            {pages.map((page, i) => (
              <img
                src={page.src}
                alt={page.alt}
                class:list={[
                  'comic-page w-full h-auto select-none',
                  i === 0 ? '' : 'hidden',
                ]}
                data-page={i}
                loading={i < 2 ? 'eager' : 'lazy'}
                draggable="false"
              />
            ))}
          </div>
        </div>

        <div class="mt-4 flex flex-col items-center gap-3">
          <div class="flex items-center gap-4">
            <span id="comic-counter" class="text-sm font-semibold text-dark dark:text-white" aria-live="polite">
              1 {t(lang, 'comic.page_of')} {totalPages}
            </span>
          </div>

          <div class="flex gap-1.5 flex-wrap justify-center" role="group" aria-label="Pages">
            {pages.map((_, i) => (
              <button
                data-goto={i}
                type="button"
                class:list={[
                  'comic-dot w-2.5 h-2.5 rounded-full transition-all duration-200',
                  i === 0
                    ? 'bg-primary-500 scale-125'
                    : 'bg-gray-300 dark:bg-gray-600 hover:bg-primary-400',
                ]}
                aria-label={`${t(lang, 'comic.page_label')} ${i + 1}`}
              />
            ))}
          </div>

          <div class="w-full max-w-md h-1 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
            <div id="comic-progress" class="h-full bg-gradient-to-r from-primary-500 to-lime-500 rounded-full transition-all duration-300" style={`width: ${100 / totalPages}%`}></div>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline define:vars={{ totalPages, pageOfLabel: t('en', 'comic.page_of') }}>
  (function() {
    let current = 0;
    const pages = document.querySelectorAll('.comic-page');
    const dots = document.querySelectorAll('.comic-dot');
    const prevBtn = document.getElementById('comic-prev');
    const nextBtn = document.getElementById('comic-next');
    const counter = document.getElementById('comic-counter');
    const progress = document.getElementById('comic-progress');

    function showPage(index) {
      if (index < 0 || index >= totalPages) return;
      pages.forEach((p, i) => p.classList.toggle('hidden', i !== index));
      dots.forEach((d, i) => {
        d.classList.toggle('bg-primary-500', i === index);
        d.classList.toggle('scale-125', i === index);
        d.classList.toggle('bg-gray-300', i !== index);
        d.classList.toggle('dark:bg-gray-600', i !== index);
      });
      current = index;
      counter.textContent = `${current + 1} ${pageOfLabel} ${totalPages}`;
      progress.style.width = `${((current + 1) / totalPages) * 100}%`;
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current === totalPages - 1;
    }

    prevBtn.addEventListener('click', () => showPage(current - 1));
    nextBtn.addEventListener('click', () => showPage(current + 1));

    dots.forEach(dot => {
      dot.addEventListener('click', () => showPage(parseInt(dot.dataset.goto)));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') showPage(current - 1);
      if (e.key === 'ArrowRight') showPage(current + 1);
    });

    let touchStartX = 0;
    const canvas = document.getElementById('comic-canvas');
    canvas.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
    canvas.addEventListener('touchend', (e) => {
      const diff = e.changedTouches[0].screenX - touchStartX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) showPage(current - 1);
        else showPage(current + 1);
      }
    }, { passive: true });

    showPage(0);
  })();
</script>
