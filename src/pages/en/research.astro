---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
const objectives = t(lang, 'research.objectives') as string[];

const workPackages = [
  { key: 'wp1', icon: '🔗' },
  { key: 'wp2', icon: '🧠' },
  { key: 'wp3', icon: '🎯' },
];
---

<BaseLayout lang={lang} currentPath="/research/" title={`${t(lang, 'research.title')} — MoS-T`}>
  <div class="pt-24 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-dark dark:text-white mb-4">
        {t(lang, 'research.title')}
      </h1>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-500 to-lime-500 rounded-full"></div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
      <h2 class="text-2xl md:text-3xl font-bold text-dark dark:text-white mb-8">
        {t(lang, 'research.objectives_title')}
      </h2>
      <div class="space-y-4">
        {objectives.map((obj, i) => (
          <div class="flex items-start gap-4 p-5 rounded-xl bg-white dark:bg-dark border border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md transition-shadow">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-gradient-to-r from-primary-500 to-lime-500 text-dark font-bold text-sm shrink-0">
              {i + 1}
            </span>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{obj}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-dark dark:text-white mb-8">
        {t(lang, 'research.wp_title')}
      </h2>
      <div class="grid md:grid-cols-3 gap-6">
        {workPackages.map((wp) => (
          <div class="group relative bg-white dark:bg-dark rounded-2xl p-8 border border-gray-100 dark:border-gray-800 shadow-lg shadow-primary-500/5 hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 transition-all duration-300">
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary-500 to-lime-500 rounded-t-2xl"></div>
            <span class="text-4xl mb-4 block">{wp.icon}</span>
            <h3 class="text-xl font-bold text-dark dark:text-white mb-3">
              {t(lang, `research.${wp.key}_title`)}
            </h3>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
              {t(lang, `research.${wp.key}_desc`)}
            </p>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
