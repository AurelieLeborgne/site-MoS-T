---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';
import publications from '../../data/publications.json';

const lang = 'en';

const types = [
  { key: 'all', label: t(lang, 'publications.filter_all') as string },
  { key: 'journal', label: t(lang, 'publications.filter_journal') as string },
  { key: 'conf_int', label: t(lang, 'publications.filter_conf_int') as string },
  { key: 'conf_nat', label: t(lang, 'publications.filter_conf_nat') as string },
];
---

<BaseLayout lang={lang} currentPath="/publications/" title={`${t(lang, 'publications.title')} — MoS-T`}>
  <div class="pt-24 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-dark dark:text-white mb-4">
        {t(lang, 'publications.title')}
      </h1>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-500 to-lime-500 rounded-full mb-4"></div>
      <p class="text-sm text-gray-500 dark:text-gray-400">{t(lang, 'publications.source_hal')}</p>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
      <div class="flex flex-wrap gap-2" id="pub-filters">
        {types.map(({ key, label }) => (
          <button
            data-filter={key}
            class:list={[
              'px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border',
              key === 'all'
                ? 'bg-primary-500 text-white border-primary-500'
                : 'bg-white dark:bg-dark text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-700 hover:border-primary-500 hover:text-primary-500',
            ]}
          >
            {label}
          </button>
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {publications.length === 0 ? (
        <p class="text-gray-500 dark:text-gray-400 text-center py-12">{t(lang, 'publications.no_results')}</p>
      ) : (
        <div class="space-y-4" id="pub-list">
          {publications.map((pub: any) => (
            <article data-type={pub.type} class="pub-item bg-white dark:bg-dark rounded-xl p-6 border border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md hover:border-primary-500/30 transition-all duration-200">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <h3 class="text-lg font-semibold text-dark dark:text-white mb-2 leading-snug">
                    {pub.url ? (
                      <a href={pub.url} target="_blank" rel="noopener noreferrer" class="hover:text-primary-500 transition-colors">
                        {pub.title}
                      </a>
                    ) : pub.title}
                  </h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">{pub.authors.join(', ')}</p>
                  <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 dark:text-gray-500">
                    {pub.venue && <span class="italic">{pub.venue}</span>}
                    <span>{pub.year}</span>
                    {pub.doi && (
                      <a href={`https://doi.org/${pub.doi}`} target="_blank" rel="noopener noreferrer" class="text-primary-500 hover:underline">
                        DOI
                      </a>
                    )}
                    {pub.halId && (
                      <a href={pub.url} target="_blank" rel="noopener noreferrer" class="text-primary-500 hover:underline">
                        HAL
                      </a>
                    )}
                  </div>
                </div>
                <span class:list={[
                  'shrink-0 px-3 py-1 rounded-full text-xs font-medium',
                  pub.type === 'journal' ? 'bg-primary-500/10 text-primary-600 dark:text-primary-400' :
                  pub.type === 'conf_int' ? 'bg-lime-500/10 text-lime-700 dark:text-lime-400' :
                  'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400'
                ]}>
                  {pub.type === 'journal' ? 'Journal' : pub.type === 'conf_int' ? 'Int. Conf.' : pub.type === 'conf_nat' ? 'Nat. Conf.' : pub.type}
                </span>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<script is:inline>
  document.querySelectorAll('#pub-filters button').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      document.querySelectorAll('#pub-filters button').forEach(b => {
        b.classList.remove('bg-primary-500', 'text-white', 'border-primary-500');
        b.classList.add('bg-white', 'dark:bg-dark', 'text-gray-600', 'dark:text-gray-300', 'border-gray-200', 'dark:border-gray-700');
      });
      btn.classList.add('bg-primary-500', 'text-white', 'border-primary-500');
      btn.classList.remove('bg-white', 'dark:bg-dark', 'text-gray-600', 'dark:text-gray-300', 'border-gray-200', 'dark:border-gray-700');
      document.querySelectorAll('.pub-item').forEach(item => {
        if (filter === 'all' || item.dataset.type === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>
