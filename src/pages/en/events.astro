---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
const base = import.meta.env.BASE_URL;

const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
function formatDate(d: string) {
  const [y, m] = d.split('-');
  return `${months[parseInt(m, 10) - 1]} ${y}`;
}

const events = [
  { date: '2022-03', title: 'MoS-T project kickoff meeting', type: 'meeting' },
  { date: '2023-06', title: 'Progress meeting — Strasbourg', type: 'meeting' },
  { date: '2024-05', title: 'Neurocomputing publication — Survey Deep Learning on Spatiotemporal Graphs', type: 'publication' },
  { date: '2025-03', title: 'Progress meeting — Strasbourg', type: 'meeting' },
  { date: '2026-03', title: 'End-of-project workshop — Analysis and Management of Medical Spatio-Temporal Data (Villejuif)', type: 'workshop' , poster: `${base}/images/events/workshop-Affiche.png` },
  { date: '2026-04', title: 'Public outreach conference — Barr', type: 'conference', poster: `${base}/images/events/conf-barr-2026.png`, details: 'Médiathèque, 34 Avenue des Vosges — Tuesday April 21 at 2:30 PM\n"Discovering an original AI to explore spatial and temporal data"\nAurélie Leborgne (University of Strasbourg) & Antoine Vacavant (University Clermont-Auvergne / Institut Pascal)' },
];
---

<BaseLayout lang={lang} currentPath="/events/" title={`${t(lang, 'events.title')} — MoS-T`} description="MoS-T project events: progress meetings, workshops and conferences on spatio-temporal modeling.">
  <div class="pt-24 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-dark dark:text-white mb-4">
        {t(lang, 'events.title')}
      </h1>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-500 to-lime-500 rounded-full"></div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary-500 to-lime-500"></div>
        <div class="space-y-8">
          {events.reverse().map((event) => (
            <div class="relative pl-12">
              <div class="absolute left-2 top-2 w-5 h-5 rounded-full bg-primary-500 border-4 border-light dark:border-darker"></div>
              <div class="bg-white dark:bg-dark rounded-xl p-6 border border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md transition-shadow">
                <time class="text-sm font-medium text-primary-500 dark:text-primary-400">{formatDate(event.date)}</time>
                <h3 class="text-lg font-semibold text-dark dark:text-white mt-1">{event.title}</h3>
                <span class="inline-block mt-2 px-3 py-1 rounded-full text-xs font-medium bg-primary-500/10 text-primary-600 dark:text-primary-400">
                  {event.type === 'meeting' ? 'Meeting' : event.type === 'publication' ? 'Publication' : event.type === 'workshop' ? 'Workshop' : event.type === 'conference' ? 'Conference' : 'Event'}
                </span>
                {event.details && (
                  <p class="mt-3 text-sm text-gray-600 dark:text-gray-400 whitespace-pre-line">{event.details}</p>
                )}
                {event.poster && (
                  <div class="mt-4">
                    <a href={`#poster-${event.date}`} class="inline-flex items-center gap-3 group">
                      <img src={event.poster} alt="Event poster" class="w-20 h-28 object-cover rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm group-hover:shadow-md transition-shadow" />
                      <span class="text-sm font-medium text-primary-600 dark:text-primary-400 group-hover:underline">View poster</span>
                    </a>
                    <div id={`poster-${event.date}`} class="poster-lightbox">
                      <a href="#!" class="poster-lightbox-overlay" aria-label="Close"></a>
                      <div class="poster-lightbox-content">
                        <a href="#!" class="poster-lightbox-close" aria-label="Close">&times;</a>
                        <img src={event.poster} alt="Event poster" />
                      </div>
                    </div>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <style>
    .poster-lightbox {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
      visibility: hidden;
      opacity: 0;
      transition: opacity 0.25s, visibility 0.25s;
    }
    .poster-lightbox:target {
      visibility: visible;
      opacity: 1;
    }
    .poster-lightbox-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.7);
      cursor: pointer;
    }
    .poster-lightbox-content {
      position: relative;
      z-index: 101;
      max-width: 90vw;
      max-height: 90vh;
    }
    .poster-lightbox-content img {
      max-width: 90vw;
      max-height: 85vh;
      border-radius: 0.75rem;
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
    }
    .poster-lightbox-close {
      position: absolute;
      top: -1rem;
      right: -1rem;
      width: 2.5rem;
      height: 2.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: white;
      color: #1D1D1B;
      border-radius: 9999px;
      font-size: 1.5rem;
      line-height: 1;
      text-decoration: none;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
      transition: transform 0.15s;
    }
    .poster-lightbox-close:hover {
      transform: scale(1.1);
    }
  </style>
</BaseLayout>
