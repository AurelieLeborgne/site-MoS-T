---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MemberCard from '../../components/MemberCard.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
const base = '/site-MoS-T';

const permanentMembers = [
  {
    name: 'Aurélie Leborgne',
    role: 'Principal Investigator',
    affiliation: 'ICube, University of Strasbourg',
    photo: `${base}/images/members/Aurelie.jpg`,
    url: 'https://aurelieleborgne.github.io/webpage/',
    description: 'Aurélie works in the modeling and analysis of spatio-temporal data. She models data from the medical field (functional MRI) and the environmental field (RPG, Corine Land Cover) using spatio-temporal graphs, and worked on frequent pattern mining in such graphs to extract relevant information.',
  },
  {
    name: 'Antoine Vacavant',
    role: 'Co-Investigator',
    affiliation: 'Institut Pascal, University Clermont Auvergne',
    photo: `${base}/images/members/Antoine.jpg`,
    url: 'http://antoine-vacavant.eu/',
    description: 'Antoine is skilled in graph-based deep learning for image data analysis and processing. His research mainly concerns computer-aided diagnosis based on (bio)medical image analysis. He is also an instructor at the NVIDIA Deep Learning Institute.',
  },
  {
    name: 'Antonio Capobianco',
    role: 'Researcher',
    affiliation: 'ICube, University of Strasbourg',
    photo: `${base}/images/members/Antonio.jpg`,
    url: 'https://www.linkedin.com/in/antonio-capobianco-unistra',
    description: 'Antonio is a specialist in Human-Computer Interaction, Virtual Reality and 3D Interaction. He is interested in user issues, in particular for the visualization and processing of information.',
  },
  {
    name: 'Céline Meillier',
    role: 'Researcher',
    affiliation: 'ICube, University of Strasbourg',
    photo: '',
    url: 'https://images.icube.unistra.fr/index.php/C%C3%A9line_Meillier',
    description: 'Céline works on the spatio-temporal modelling of the dynamics of functional connectivity through the analysis of signals from fMRI data. She also works on multiple thresholding techniques for significant correlations of fMRI signals.',
  },
  {
    name: 'Thomas Lampert',
    role: 'Researcher',
    affiliation: 'ICube, University of Strasbourg',
    photo: `${base}/images/members/Tom.jpg`,
    url: 'https://sites.google.com/site/tomalampert',
    description: 'Thomas is an expert in machine learning, specifically deep learning and semi-supervised and unsupervised approaches. His current research focuses on domain adaptation and representation learning for image and time-series analysis.',
  },
  {
    name: 'Florence Le Ber',
    role: 'Researcher',
    affiliation: 'ICube, ENGEES',
    photo: `${base}/images/members/flbweb.png`,
    url: 'https://sdc.icube.unistra.fr/en/index.php/Florence_le_Ber',
    description: 'Florence works in modelling and representing knowledge, reasoning about space, and extracting knowledge from temporal and spatial data. Applications include agriculture, hydroecology and environmental issues.',
  },
];

const nonPermanentMembers = [
  {
    name: 'Assaad Zeghina',
    role: 'PhD Student',
    affiliation: 'ICube, University of Strasbourg',
    photo: `${base}/images/members/Assaad.jpg`,
    url: 'https://drassaadz.github.io/',
    description: 'Assaad obtained his M.S. in Machine Learning from the University of Paris. His research interests include graph neural networks, deep learning and computer vision.',
  },
  {
    name: 'Julien Pontabry',
    role: 'Research Engineer',
    affiliation: 'ICube, University of Strasbourg',
    photo: `${base}/images/members/Julien.jpg`,
    url: 'https://www.linkedin.com/in/julien-pontabry-b784a247/',
    description: 'Julien is currently a research engineer at ICube Laboratory, assigned to both the GAIA technology platform and the IMIS research team. He works on AI applied to biomedical imaging.',
  },
];
---

<BaseLayout lang={lang} currentPath="/team/" title={`${t(lang, 'team.title')} — MoS-T`} description="The MoS-T ANR project team: AI researchers in graphs and spatio-temporal series at ICube (Strasbourg) and Institut Pascal (Clermont-Ferrand).">
  <div class="pt-24 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-dark dark:text-white mb-4">
        {t(lang, 'team.title')}
      </h1>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-500 to-lime-500 rounded-full"></div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <h2 class="text-2xl md:text-3xl font-bold text-dark dark:text-white mb-8">
        {t(lang, 'team.permanent')}
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {permanentMembers.map((member) => (
          <MemberCard {...member} />
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-dark dark:text-white mb-8">
        {t(lang, 'team.non_permanent')}
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {nonPermanentMembers.map((member) => (
          <MemberCard {...member} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
