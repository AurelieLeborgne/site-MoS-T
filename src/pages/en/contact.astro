---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
---

<BaseLayout lang={lang} currentPath="/contact/" title={`${t(lang, 'contact.title')} — MoS-T`}>
  <div class="pt-24 pb-20">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-dark dark:text-white mb-4">
        {t(lang, 'contact.title')}
      </h1>
      <div class="w-20 h-1 bg-gradient-to-r from-primary-500 to-lime-500 rounded-full"></div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <div class="bg-white dark:bg-dark rounded-2xl p-8 border border-gray-100 dark:border-gray-800 shadow-lg shadow-primary-500/5">
          <div class="mb-8">
            <h2 class="text-sm font-medium text-primary-500 dark:text-primary-400 uppercase tracking-wide mb-4">
              {t(lang, 'contact.pi_label')}
            </h2>
            <p class="text-2xl font-bold text-dark dark:text-white mb-2">Aurélie Leborgne</p>
            <p class="text-gray-600 dark:text-gray-400">Associate Professor, ICube — University of Strasbourg</p>
          </div>

          <div class="mb-8">
            <h2 class="text-sm font-medium text-primary-500 dark:text-primary-400 uppercase tracking-wide mb-2">
              {t(lang, 'contact.email_label')}
            </h2>
            <a
              href="mailto:aurelie.leborgne@unistra.fr"
              class="text-lg text-dark dark:text-white hover:text-primary-500 dark:hover:text-primary-400 transition-colors"
            >
              aurelie.leborgne@unistra.fr
            </a>
          </div>

          <div class="mb-8">
            <h2 class="text-sm font-medium text-primary-500 dark:text-primary-400 uppercase tracking-wide mb-2">
              {t(lang, 'contact.address_label')}
            </h2>
            <address class="text-gray-600 dark:text-gray-400 not-italic leading-relaxed">
              ICube Laboratory — UMR 7357<br />
              300 bd Sébastien Brant<br />
              CS 10413<br />
              67412 Illkirch Cedex, France
            </address>
          </div>

          <div class="pt-6 border-t border-gray-100 dark:border-gray-800">
            <p class="text-sm text-gray-500 dark:text-gray-500">{t(lang, 'contact.anr_ref')}</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
