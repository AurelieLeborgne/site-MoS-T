---
import { type Lang, t, getLocalizedPath, getAlternateUrl, languages } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const base = '/site-MoS-T';

const navItems = [
  { key: 'home', fr: '/', en: '/' },
  { key: 'research', fr: '/recherche/', en: '/research/' },
  { key: 'team', fr: '/equipe/', en: '/team/' },
  { key: 'publications', fr: '/publications/', en: '/publications/' },
  { key: 'events', fr: '/evenements/', en: '/events/' },
  { key: 'comic', fr: '/bd/', en: '/comic/' },
  { key: 'resources', fr: '/ressources/', en: '/resources/' },
  { key: 'contact', fr: '/contact/', en: '/contact/' },
];

const otherLang = lang === 'fr' ? 'en' : 'fr';
const switchUrl = getAlternateUrl(Astro.url, otherLang);
---

<nav aria-label="Navigation principale" class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-darker/80 backdrop-blur-lg border-b border-gray-200/50 dark:border-gray-700/50 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={getLocalizedPath(lang, '/')} class="flex items-center gap-2 shrink-0">
        <img
          src={`${base}/logos/most-noir.svg`}
          alt="MoS-T"
          class="h-8 dark:hidden"
          width="120"
          height="32"
        />
        <img
          src={`${base}/logos/most-blanc.svg`}
          alt="MoS-T"
          class="h-8 hidden dark:block"
          width="120"
          height="32"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => {
          const href = getLocalizedPath(lang, item[lang]);
          const isActive = currentPath === item[lang];
          return (
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200',
                isActive
                  ? 'bg-primary-500/10 text-primary-600 dark:text-primary-400'
                  : 'text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-primary-500',
              ]}
            >
              {t(lang, `nav.${item.key}`)}
            </a>
          );
        })}
      </div>

      <!-- Right actions -->
      <div class="flex items-center gap-2">
        <!-- Language switcher -->
        <a
          href={switchUrl}
          class="inline-flex items-center rounded-full border-2 border-primary-800 dark:border-primary-400 overflow-hidden text-sm font-semibold transition-all duration-200"
          aria-label={`Switch to ${languages[otherLang]}`}
        >
          <span class:list={[
            'px-2.5 py-1',
            lang === 'fr'
              ? 'bg-primary-700 text-white dark:bg-primary-400 dark:text-darker'
              : 'text-primary-800 dark:text-primary-300 hover:bg-primary-500/10',
          ]}>FR</span>
          <span class:list={[
            'px-2.5 py-1',
            lang === 'en'
              ? 'bg-primary-700 text-white dark:bg-primary-400 dark:text-darker'
              : 'text-primary-800 dark:text-primary-300 hover:bg-primary-500/10',
          ]}>EN</span>
        </a>

        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          type="button"
          class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label={t(lang, 'common.dark_mode') as string}
        >
          <!-- Sun (shown in dark mode) -->
          <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <!-- Moon (shown in light mode) -->
          <svg class="w-5 h-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="lg:hidden p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="Menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" role="region" aria-label="Menu mobile" class="hidden lg:hidden border-t border-gray-200/50 dark:border-gray-700/50 bg-white/95 dark:bg-darker/95 backdrop-blur-lg">
    <div class="px-4 py-3 space-y-1">
      {navItems.map((item) => {
        const href = getLocalizedPath(lang, item[lang]);
        const isActive = currentPath === item[lang];
        return (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'block px-3 py-2 rounded-lg text-base font-medium transition-all duration-200',
              isActive
                ? 'bg-primary-500/10 text-primary-600 dark:text-primary-400'
                : 'text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800',
            ]}
          >
            {t(lang, `nav.${item.key}`)}
          </a>
        );
      })}
    </div>
  </div>
</nav>

<script is:inline>
  // Dark mode toggle
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const html = document.documentElement;
    html.classList.toggle('dark');
    localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
  });

  // Mobile menu toggle
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    const btn = document.getElementById('mobile-menu-btn');
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn?.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
