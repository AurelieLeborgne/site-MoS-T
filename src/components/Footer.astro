---
import { type Lang, t } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = '/site-MoS-T';

const partners = [
  { name: 'ANR', logo: `${base}/images/partners/logoAnr2.png`, url: 'https://anr.fr/', dark: false },
  { name: 'CNRS', logo: `${base}/images/partners/logoCNRS.png`, url: 'https://www.cnrs.fr/', dark: false },
  { name: 'ICube', logo: `${base}/images/partners/logoIcube.png`, url: 'https://icube.unistra.fr/', dark: false },
  { name: 'Université de Strasbourg', logo: `${base}/images/partners/logoUnistra.png`, url: 'https://www.unistra.fr/', dark: true },
  { name: 'Institut Pascal', logo: `${base}/images/partners/logoInstitutPascal.jpg`, url: 'https://www.institut-pascal.fr/', dark: false },
];
---

<footer role="contentinfo" class="bg-dark text-gray-300 mt-auto">
  <!-- Partners banner -->
  <div class="border-b border-gray-700/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <p class="text-center text-sm text-gray-400 mb-6">{t(lang, 'footer.funded_by')}</p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
        {partners.map((partner) => (
          <a
            href={partner.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-lg px-4 py-2 hover:bg-white/10 transition-all duration-300"
            title={`${partner.name} (nouvelle fenêtre)`}
          >
            <img
              src={partner.logo}
              alt={partner.name}
              class:list={[
                'h-10 md:h-12 w-auto object-contain opacity-80 hover:opacity-100 transition-all duration-300 rounded',
                partner.dark && 'invert',
              ]}
              loading="lazy"
            />
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <div class="flex items-center gap-3">
        <img src={`${base}/logos/most-blanc.svg`} alt="MoS-T" class="h-6" width="90" height="24" />
        <span>|</span>
        <a href="https://anr.fr/Projet-ANR-21-CE23-0015" target="_blank" rel="noopener noreferrer" class="hover:text-primary-400 transition-colors" title="Projet ANR MoS-T (nouvelle fenêtre)">{t(lang, 'footer.anr_ref')}<span class="sr-only"> (nouvelle fenêtre)</span></a>
      </div>
      <p>{t(lang, 'footer.copyright')}</p>
    </div>
  </div>
</footer>
