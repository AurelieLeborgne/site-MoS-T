---
import { type Lang, t } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = '/site-MoS-T';

const partners = [
  { name: 'ANR', logo: `${base}/images/partners/logoAnr2.png`, url: 'https://anr.fr/' },
  { name: 'CNRS', logo: `${base}/images/partners/logoCNRS.png`, url: 'https://www.cnrs.fr/' },
  { name: 'ICube', logo: `${base}/images/partners/logoIcube.png`, url: 'https://icube.unistra.fr/' },
  { name: 'Université de Strasbourg', logo: `${base}/images/partners/logoUnistra.png`, url: 'https://www.unistra.fr/' },
  { name: 'Institut Pascal', logo: `${base}/images/partners/logoInstitutPascal.jpg`, url: 'https://www.institut-pascal.fr/' },
];
---

<footer class="bg-dark text-gray-300 mt-auto">
  <!-- Partners banner -->
  <div class="border-b border-gray-700/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <p class="text-center text-sm text-gray-400 mb-6">{t(lang, 'footer.funded_by')}</p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
        {partners.map((partner) => (
          <a
            href={partner.url}
            target="_blank"
            rel="noopener noreferrer"
            class="opacity-70 hover:opacity-100 transition-opacity duration-200"
            title={partner.name}
          >
            <img
              src={partner.logo}
              alt={partner.name}
              class="h-10 md:h-12 w-auto object-contain bg-white rounded-lg p-1.5"
              loading="lazy"
            />
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <div class="flex items-center gap-3">
        <img src={`${base}/logos/most-blanc.svg`} alt="MoS-T" class="h-6" width="90" height="24" />
        <span>|</span>
        <span>{t(lang, 'footer.anr_ref')}</span>
      </div>
      <p>{t(lang, 'footer.copyright')}</p>
    </div>
  </div>
</footer>
